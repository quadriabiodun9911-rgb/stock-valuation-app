# Core application settings
APP_ENV=production
PORT=8000
API_KEY=replace-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006,http://localhost:8123
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\\d+)?$
ALLOWED_HOSTS=*,localhost,127.0.0.1
ENABLE_HTTPS_REDIRECT=false
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO
MARKET_CACHE_TTL_SECONDS=300
MARKET_STALE_CACHE_TTL_SECONDS=1800
MARKET_FETCH_BACKOFF_SECONDS=30

# AI / LLM Configuration
# Choose AI provider: "ollama" (free, local) or "openai" (cloud, cost per request)
AI_PROVIDER=ollama

# Ollama Configuration (for local AI - free)
# Install: brew install ollama
# Download model: ollama pull mistral
# Run: ollama serve
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenAI Configuration (cloud-based, ~$0.015 per chat)
# Get API key from: https://platform.openai.com/api-keys
# To use: set AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here

# Persistence
# SQLite is used by default. Set DATABASE_URL to a PostgreSQL connection
# string in production, for example from Render or Railway.
DATABASE_URL=

# Smart Strategy optional configuration
# Redis URL for job persistence (optional)
SMART_STRATEGY_REDIS_URL=redis://localhost:6379/0

# API key to protect smart-strategy endpoints (optional)
SMART_STRATEGY_API_KEY=your-api-key-here

# Max symbols per request (env cap)
SMART_STRATEGY_MAX_SYMBOLS=12

# Per-symbol processing timeout seconds
SMART_STRATEGY_SYMBOL_TIMEOUT=15

# Retention (days) for persisted job results
SMART_STRATEGY_RETENTION_DAYS=7
SMART_STRATEGY_RETENTION_INTERVAL=3600

# Prometheus metrics server port (optional)
PROMETHEUS_METRICS_PORT=8001
